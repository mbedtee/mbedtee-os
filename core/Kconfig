menu "General Setup"

config NR_CPUS
	int "CPU Cores Num"
	help
		Configure the number of the CPU cores.

config PRINTK
	bool "Enable printk"
	help
		Say Y here to enable the kernel print.

config TRACE_LEVEL
	int "xMSG level"
	default 3
	depends on PRINTK
	help
		Configure the kernel trace xMSG level.
		TRACE_LEVEL_IGNORE 0
		TRACE_LEVEL_ERROR  1
		TRACE_LEVEL_WARN   2
		TRACE_LEVEL_INFO   3
		TRACE_LEVEL_DEBUG  4
		TRACE_LEVEL_LOG    5
		TRACE_LEVEL_FS     6

config VMALLOC
	bool "Enable vmalloc"
	default y
	depends on MMU
	help
		Say Y to enable use of the contiguous
		virtual address space mmaped with scattered pages

config STACK_PROTECTOR
	bool "Enable stack protector"
	default y
	help
		Say Y here to enable the stack protector.

config BACKTRACE
	bool "Enable kernel unwind backtrace"
	help
		Say Y here to enable the kernel unwind backtrace.

config EMBEDDED_DTB
	bool "Enable the embedded DTB"
	default y
	help
		Say Y to use the embedded DTB,
	  	DTB will be linked into kernel

config DTB_ADDR
	hex "DTB load address"
	default 0x82000000
	depends on !EMBEDDED_DTB
	help
		Configure the external DTB address
		when EMBEDDED_DTB is not enabled.

config OS_ADDR
	hex "OS link address"
	default 0x80100000 if MIPS32
	default 0xC0000000 if AARCH32 && USER
	default 0x80100000 if AARCH32 && !USER
	default 0xC0000000 if RISCV32 && USER
	default 0x80000000 if RISCV32 && !USER
	default 0x80000000 if AARCH64 && !USER
	default 0x80000000 if RISCV64 && !USER
	default 0xFFFFFFE000000000 if RISCV64 && USER
	default 0xFFFFFFC000000000 if AARCH64 && USER
	help
		Configure the OS destination link address.

choice
	prompt "Kernel Heap Allocator"
	default KMALLOC_SLAB
	help
		Select the kernel heap sub-page allocator.

config KMALLOC_SLAB
	bool "Slab allocator"
	help
		Use a pure SLAB allocator for all sub-page allocations.
		Objects are served from per-class freelists (up to 1024 bytes).
		Uses O(1) multi-list approach (partial/full) for high performance.
		Larger requests are served directly by the page allocator.

config KMALLOC_SLAB_BUDDY
	bool "Slab + Buddy allocator"
	help
		Use the SLAB allocator for sub-page allocations.
		Objects are served from per-class freelists
		backed by a buddy allocator for larger requests.

config KMALLOC_BITMAP_BUDDY
	bool "Bitmap + Buddy allocator"
	help
		Use the bitmap allocator for sub-page allocations.
		Small objects are tracked via per-page bitmaps,
		larger requests use a buddy allocator.

endchoice

source "core/elf/Kconfig"

endmenu
